// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users/{userId}/memory
// Document ID: profile
// Fields:
//   - facts: list of strings (required) - Facts about the user
//   - summary: string (optional) - Summary of interactions
//   - updatedAt: timestamp (required) - Last update time
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "denyteny123@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUserMemory(data) {
      return data.keys().hasAll(['facts', 'updatedAt']) &&
             data.facts is list &&
             data.updatedAt is timestamp &&
             (!('summary' in data) || data.summary is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /memory/profile {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if (isOwner(userId) || isAdmin()) && isValidUserMemory(request.resource.data);
        allow delete: if isAdmin();
      }
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
